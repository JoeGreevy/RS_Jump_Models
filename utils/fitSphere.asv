function [c, r] = fitSphere(pts)
%FITSPHERE Fit sphere to points
%   09/04/26
%   Taken from func_hjc.m,
%   Adapted from Claude, https://www.geometrictools.com/Documentation/LeastSquaresFitting.pdf
%   https://jekel.me/2015/Least-Squares-Sphere-Fit/
arguments (Input)
    pts
end

arguments (Output)
    c
    r
end

N = size(pts, 1);
A = [2*pts ones([N, 1])];
b = sum(pts .* pts, 2); % x^2 + y^2 + x^2
% Least Squares Solve
Atb = A.' * b;
AtA = A.'*A;
%x = AtA\Atb;
x = pinv(AtA) * Atb;
r = sqrt(x(4) + x(1)^2 + x(2)^2 + x(3)^2);
c = x(1:3);
end