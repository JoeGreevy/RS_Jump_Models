function c = getHaraHJC(markerStruct)
%GETHARAHJC Hara 2016 Regression Equations
%   Detailed explanation goes here
arguments (Input)
    markerStruct
end

arguments (Output)
    c
end
% ===== Get Leg Length ===== %
thigh_len = mean(vecnorm(markerStruct.("R_ASIS") - markerStruct.("V_R_MedialFemoralEpicondyle"), 2, 2));

c = [   11 - 0.063 * ll, ...
        8 + 0.086 * ll,...
        -9 - 0.078 * ll  ] ./ 1000;
end